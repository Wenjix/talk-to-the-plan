# WARNING: VITE_* env vars are inlined into the JS bundle at build time.
# These are for LOCAL DEVELOPMENT ONLY. Never set these on Vercel or any
# public deployment — the keys will be visible in the browser source.
# In production, users should enter keys via the Settings UI (stored in IndexedDB).
VITE_MISTRAL_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_EIGEN_API_KEY=
VITE_BOSON_API_KEY=
